# Shared baseline environment variables managed by supervisor-foundation
# Downstream services may add service-local keys in owned directories.

# Runtime defaults
SMARTCLOUD_ENV=dev
SMARTCLOUD_LOG_LEVEL=INFO
SMARTCLOUD_TIMEZONE=Asia/Shanghai
SMARTCLOUD_DEFAULT_LOCALE=zh-CN
SMARTCLOUD_CORS_ALLOWED_ORIGINS=http://localhost:8050,http://127.0.0.1:8050,http://localhost:5173,http://127.0.0.1:5173
# Shared segmented-prefix convention used directly by rag-service and knowledge-service.
# Flat-route services (orchestrator/tool-hub/business-tools) keep their own canonical local prefixes.
SMARTCLOUD_API_PREFIX=/api
SMARTCLOUD_API_VERSION=v1
SMARTCLOUD_MYSQL_DSN=mysql+pymysql://smartcloud:smartcloud@mysql:3306/smartcloud
SMARTCLOUD_REDIS_URL=redis://redis:6379/0
SMARTCLOUD_MINIO_ENDPOINT=http://minio:9000
SMARTCLOUD_MINIO_BUCKET=knowledge-raw
SMARTCLOUD_MINIO_ACCESS_KEY=smartcloud
SMARTCLOUD_MINIO_SECRET_KEY=replace-me

# Auth baseline
SMARTCLOUD_AUTH_ISSUER=smartcloud-x
SMARTCLOUD_AUTH_AUDIENCE=smartcloud-x-clients
SMARTCLOUD_INTERNAL_AUTH_AUDIENCE=smartcloud-x-internal
SMARTCLOUD_JWT_ALGORITHM=HS256
SMARTCLOUD_JWT_SECRET=replace-me
SMARTCLOUD_TOKEN_TTL_MINUTES=120

# Request coordination
SMARTCLOUD_REQUEST_TIMEOUT_MS=10000
SMARTCLOUD_SSE_HEARTBEAT_INTERVAL_SECONDS=15
# Shared allow-list key name reused by trusted internal HTTP services.
# Each service must override this with its own caller identities.
ALLOWED_INTERNAL_CALLERS=replace-with-service-specific-callers
# Shared provider-transport prefix overrides used by orchestrator/tool-hub HTTP discovery.
BUSINESS_TOOLS_INTERNAL_API_PREFIX=/internal/v1
TOOL_HUB_INTERNAL_API_PREFIX=/internal/v1
SMARTCLOUD_TRACE_ENABLED=true
SMARTCLOUD_REQUEST_ID_HEADER=X-Request-Id
SMARTCLOUD_TRACE_ID_HEADER=X-Trace-Id
SMARTCLOUD_CONVERSATION_ID_HEADER=X-Conversation-Id
SMARTCLOUD_TENANT_ID_HEADER=X-Tenant-Id
SMARTCLOUD_CALLER_SERVICE_HEADER=X-Caller-Service
SMARTCLOUD_TOOL_CALL_ID_HEADER=X-Tool-Call-Id
SMARTCLOUD_IDEMPOTENCY_KEY_HEADER=Idempotency-Key
SMARTCLOUD_OPERATOR_REASON_HEADER=X-Operator-Reason

# Observability
SMARTCLOUD_LANGSMITH_ENABLED=false
SMARTCLOUD_LANGSMITH_PROJECT=smartcloud-x-local
SMARTCLOUD_PHOENIX_ENABLED=false
SMARTCLOUD_PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006/v1/traces
