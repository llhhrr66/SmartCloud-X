# These values are read by Vite during local dev/build and can also be supplied
# to the container runtime, where runtime-config.js will override the built defaults.
VITE_APP_TITLE=SmartCloud-X User Console
VITE_APP_VERSION=0.1.0
VITE_API_BASE_URL=http://localhost:8000
VITE_USE_MOCK_API=false
VITE_REQUEST_TIMEOUT_MS=30000
VITE_SSE_HEARTBEAT_SECONDS=15
