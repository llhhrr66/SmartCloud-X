SMARTCLOUD_LOG_LEVEL=INFO
SMARTCLOUD_TRACE_ENABLED=true
SMARTCLOUD_REQUEST_TIMEOUT_MS=10000
SMARTCLOUD_OPERATOR_REASON_HEADER=X-Operator-Reason
SMARTCLOUD_CORS_ALLOWED_ORIGINS=http://localhost:8050,http://127.0.0.1:8050,http://localhost:5173,http://127.0.0.1:5173

# Required runtime baseline
SMARTCLOUD_MYSQL_DSN=mysql+pymysql://smartcloud:smartcloud@mysql:3306/smartcloud
AUTH_USER_SERVICE_BASE_URL=http://auth-user-service:8001
MARKETING_SERVICE_BASE_URL=http://marketing-service:8002
RESEARCH_SERVICE_BASE_URL=http://research-service:8003
ORCHESTRATOR_SERVICE_BASE_URL=http://orchestrator-service:8010
TOOL_HUB_SERVICE_BASE_URL=http://tool-hub-service:8020
BUSINESS_TOOLS_SERVICE_BASE_URL=http://business-tools-service:8030
RAG_SERVICE_BASE_URL=http://rag-service:8040
SMARTCLOUD_MONGODB_URI=mongodb://mongo:27017
SMARTCLOUD_MONGODB_DATABASE=smartcloud
SMARTCLOUD_REDIS_URL=redis://redis:6379/0
SMARTCLOUD_MINIO_ENDPOINT=http://minio:9000
SMARTCLOUD_MINIO_BUCKET=knowledge-raw
SMARTCLOUD_MINIO_ACCESS_KEY=smartcloud
SMARTCLOUD_MINIO_SECRET_KEY=smartcloud123
SMARTCLOUD_QDRANT_URL=http://qdrant:6333
SMARTCLOUD_QDRANT_COLLECTION=knowledge_chunks
SMARTCLOUD_QDRANT_VECTOR_SIZE=32
SMARTCLOUD_OPENSEARCH_URL=http://opensearch:9200
SMARTCLOUD_EMBEDDING_PROVIDER=hash-baseline
SMARTCLOUD_EMBEDDING_API_URL=
SMARTCLOUD_EMBEDDING_API_KEY=
SMARTCLOUD_EMBEDDING_MODEL=
SMARTCLOUD_LLM_API_KEY=
SMARTCLOUD_LLM_BASE_URL=
SMARTCLOUD_LLM_MODEL=
SMARTCLOUD_JWT_SECRET=replace-me

# Knowledge / RAG runtime paths
SMARTCLOUD_KNOWLEDGE_DATA_PATH=/app/runtime/knowledge-store.json
SMARTCLOUD_KNOWLEDGE_AUDIT_PATH=/app/runtime/knowledge-admin-audit.jsonl
SMARTCLOUD_KNOWLEDGE_OUTBOX_PATH=/app/runtime/knowledge-indexing-outbox.jsonl
SMARTCLOUD_KNOWLEDGE_IMPORT_ROOT=/app/imports
SMARTCLOUD_KNOWLEDGE_RAW_MIRROR_ROOT=/app/runtime/raw-objects
SMARTCLOUD_RAG_REDIS_URL=redis://redis:6379/1
SMARTCLOUD_RAG_CACHE_ENABLED=true
# Host-side knowledge-service uses http://localhost:8031; compose containers use http://knowledge-service:8030.
KNOWLEDGE_SERVICE_BASE_URL=http://knowledge-service:8030
# When running gateway-service on the host instead of inside compose, override service base URLs to localhost ports.

# Optional enhancement
SMARTCLOUD_CONNECTOR_TIMEOUT_MS=5000
SMARTCLOUD_INDEX_WORKER_POLL_SECONDS=2
SMARTCLOUD_INDEX_WORKER_BATCH_SIZE=10
SMARTCLOUD_DIFY_EXTERNAL_KNOWLEDGE_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=smartcloud-x-local
LANGSMITH_API_KEY=

# Observability only
SMARTCLOUD_PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://phoenix:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Frontend build variables
VITE_API_BASE_URL=http://localhost:8000
VITE_USE_MOCK_API=false
VITE_KNOWLEDGE_SERVICE_BASE_URL=http://localhost:8031/api/knowledge/v1
VITE_RAG_SERVICE_BASE_URL=http://localhost:8040/api/rag/v1
VITE_OPERATOR_REASON_HEADER=X-Operator-Reason

MINIO_ROOT_USER=smartcloud
MINIO_ROOT_PASSWORD=smartcloud123
SMARTCLOUD_MINIO_HOST_PORT=19000
SMARTCLOUD_MINIO_CONSOLE_HOST_PORT=19001
MYSQL_DATABASE=smartcloud
MYSQL_USER=smartcloud
MYSQL_PASSWORD=smartcloud
MYSQL_ROOT_PASSWORD=smartcloud-root
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Smartcloud123!
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
SMARTCLOUD_SMOKE_TIMEOUT_SECONDS=5
