{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/admin/admin-action-confirmation-request.schema.json",
  "title": "AdminActionConfirmationRequest",
  "type": "object",
  "required": [
    "action",
    "resource_scope",
    "verification_method",
    "verification_payload"
  ],
  "properties": {
    "action": {
      "type": "string",
      "minLength": 1
    },
    "resource_scope": {
      "type": "string",
      "minLength": 1
    },
    "verification_method": {
      "type": "string",
      "enum": [
        "password",
        "sms",
        "totp",
        "webauthn"
      ]
    },
    "verification_payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
