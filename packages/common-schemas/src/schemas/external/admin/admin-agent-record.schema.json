{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/admin/admin-agent-record.schema.json",
  "title": "AdminAgentRecord",
  "type": "object",
  "required": [
    "name",
    "code",
    "display_name",
    "domain",
    "description"
  ],
  "properties": {
    "name": {
      "$ref": "../../internal/orchestrator/agent-name.schema.json"
    },
    "code": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "supported_scenes": {
      "type": "array",
      "items": {
        "$ref": "../../internal/orchestrator/scene-name.schema.json"
      }
    },
    "tool_whitelist": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fallback_agent": {
      "type": "string",
      "minLength": 1
    },
    "max_tool_calls": {
      "type": "integer",
      "minimum": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}
