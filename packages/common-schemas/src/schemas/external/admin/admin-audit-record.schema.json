{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/admin/admin-audit-record.schema.json",
  "title": "AdminAuditRecord",
  "type": "object",
  "required": [
    "audit_id",
    "operator_type",
    "operator_id",
    "resource_type",
    "resource_id",
    "action",
    "reason",
    "created_at"
  ],
  "properties": {
    "audit_id": {
      "type": "string",
      "minLength": 1
    },
    "operator_type": {
      "type": "string",
      "minLength": 1
    },
    "operator_id": {
      "type": "string",
      "minLength": 1
    },
    "resource_type": {
      "type": "string",
      "minLength": 1
    },
    "resource_id": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "before_json": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "after_json": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "operator_ip": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
