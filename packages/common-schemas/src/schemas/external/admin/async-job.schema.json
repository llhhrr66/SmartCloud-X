{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/admin/async-job.schema.json",
  "title": "AdminAsyncJob",
  "type": "object",
  "required": [
    "job_id",
    "type",
    "status",
    "progress",
    "created_at"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "progress": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "params": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "result_file_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "error_message": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "finished_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
