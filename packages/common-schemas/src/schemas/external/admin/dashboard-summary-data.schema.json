{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/admin/dashboard-summary-data.schema.json",
  "title": "AdminDashboardSummaryData",
  "type": "object",
  "required": [
    "conversation_count",
    "error_count",
    "active_alert_count",
    "p95_latency_ms",
    "total_cost"
  ],
  "properties": {
    "conversation_count": {
      "type": "integer",
      "minimum": 0
    },
    "error_count": {
      "type": "integer",
      "minimum": 0
    },
    "active_alert_count": {
      "type": "integer",
      "minimum": 0
    },
    "p95_latency_ms": {
      "type": "integer",
      "minimum": 0
    },
    "total_cost": {
      "type": "number",
      "minimum": 0
    },
    "date_from": {
      "type": "string",
      "format": "date"
    },
    "date_to": {
      "type": "string",
      "format": "date"
    }
  },
  "additionalProperties": false
}
