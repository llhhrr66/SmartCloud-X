{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/admin/knowledge-base-update-request.schema.json",
  "title": "AdminKnowledgeBaseUpdateRequest",
  "type": "object",
  "minProperties": 1,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "retrieval_mode": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "disabled"
      ]
    }
  },
  "additionalProperties": false
}
