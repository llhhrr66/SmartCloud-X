{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/admin/knowledge-base.schema.json",
  "title": "AdminKnowledgeBase",
  "type": "object",
  "required": [
    "kb_id",
    "code",
    "name",
    "scene",
    "language",
    "retrieval_mode",
    "status"
  ],
  "properties": {
    "kb_id": {
      "type": "string",
      "minLength": 1
    },
    "code": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "scene": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "retrieval_mode": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "document_count": {
      "type": "integer",
      "minimum": 0
    },
    "chunk_count": {
      "type": "integer",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
