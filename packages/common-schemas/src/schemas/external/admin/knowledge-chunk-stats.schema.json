{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/admin/knowledge-chunk-stats.schema.json",
  "title": "AdminKnowledgeChunkStats",
  "type": "object",
  "required": [
    "chunk_count",
    "token_count",
    "average_tokens_per_chunk"
  ],
  "properties": {
    "chunk_count": {
      "type": "integer",
      "minimum": 0
    },
    "token_count": {
      "type": "integer",
      "minimum": 0
    },
    "average_tokens_per_chunk": {
      "type": "number",
      "minimum": 0
    },
    "latest_job_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  },
  "additionalProperties": false
}
