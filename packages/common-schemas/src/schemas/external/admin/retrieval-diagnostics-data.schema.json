{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/admin/retrieval-diagnostics-data.schema.json",
  "title": "AdminRetrievalDiagnosticsData",
  "type": "object",
  "required": [
    "query",
    "sources"
  ],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1
    },
    "rewritten_query": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "./retrieval-search-source.schema.json"
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": true
    },
    "answerable": {
      "type": "boolean"
    },
    "debug": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
