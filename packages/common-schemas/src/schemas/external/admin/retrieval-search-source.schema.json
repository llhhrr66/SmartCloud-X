{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/admin/retrieval-search-source.schema.json",
  "title": "AdminRetrievalSearchSource",
  "type": "object",
  "required": [
    "doc_id",
    "chunk_id",
    "title",
    "score",
    "content_preview"
  ],
  "properties": {
    "doc_id": {
      "type": "string",
      "minLength": 1
    },
    "chunk_id": {
      "type": "string",
      "minLength": 1
    },
    "kb_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "score": {
      "type": "number"
    },
    "content_preview": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
