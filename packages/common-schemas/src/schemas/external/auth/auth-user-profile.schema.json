{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/auth/auth-user-profile.schema.json",
  "title": "AuthUserProfile",
  "type": "object",
  "required": [
    "user_id",
    "tenant_id",
    "name",
    "email",
    "mobile",
    "locale",
    "time_zone",
    "permissions"
  ],
  "properties": {
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "email": {
      "type": "string",
      "minLength": 1
    },
    "mobile": {
      "type": "string",
      "minLength": 1
    },
    "avatar_url": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "minLength": 1
    },
    "time_zone": {
      "type": "string",
      "minLength": 1
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
