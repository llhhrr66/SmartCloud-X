{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/auth/change-password-request.schema.json",
  "title": "ChangePasswordRequest",
  "type": "object",
  "required": [
    "old_password",
    "new_password",
    "confirm_password"
  ],
  "properties": {
    "old_password": {
      "type": "string",
      "minLength": 1
    },
    "new_password": {
      "type": "string",
      "minLength": 8
    },
    "confirm_password": {
      "type": "string",
      "minLength": 8
    }
  },
  "additionalProperties": false
}
