{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/auth/forgot-password-request.schema.json",
  "title": "ForgotPasswordRequest",
  "type": "object",
  "required": [
    "account",
    "account_type",
    "verification_code"
  ],
  "properties": {
    "account": {
      "type": "string",
      "minLength": 1
    },
    "account_type": {
      "type": "string",
      "enum": [
        "mobile",
        "email"
      ]
    },
    "verification_code": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
