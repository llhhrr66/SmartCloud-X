{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/auth/reset-password-request.schema.json",
  "title": "ResetPasswordRequest",
  "type": "object",
  "required": [
    "challenge_id",
    "account",
    "verification_code",
    "new_password",
    "confirm_password"
  ],
  "properties": {
    "challenge_id": {
      "type": "string",
      "minLength": 1
    },
    "account": {
      "type": "string",
      "minLength": 1
    },
    "verification_code": {
      "type": "string",
      "minLength": 1
    },
    "new_password": {
      "type": "string",
      "minLength": 8
    },
    "confirm_password": {
      "type": "string",
      "minLength": 8
    }
  },
  "additionalProperties": false
}
