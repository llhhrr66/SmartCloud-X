{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/canonical-success-envelope.schema.json",
  "title": "CanonicalSuccessEnvelope",
  "type": "object",
  "required": ["code", "message", "data", "request_id", "timestamp"],
  "properties": {
    "code": {
      "type": "integer",
      "const": 0
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "data": {
      "not": {
        "type": "null"
      }
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
