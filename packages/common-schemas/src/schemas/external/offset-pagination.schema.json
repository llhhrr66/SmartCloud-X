{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/offset-pagination.schema.json",
  "title": "OffsetPagination",
  "type": "object",
  "required": ["page", "page_size", "total"],
  "properties": {
    "page": {
      "type": "integer",
      "minimum": 1
    },
    "page_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "total_pages": {
      "type": "integer",
      "minimum": 0
    },
    "sort_by": {
      "type": "string",
      "minLength": 1
    },
    "sort_order": {
      "type": "string",
      "enum": ["asc", "desc"]
    }
  },
  "additionalProperties": false
}
