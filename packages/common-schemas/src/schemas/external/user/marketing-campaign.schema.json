{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/user/marketing-campaign.schema.json",
  "title": "MarketingCampaign",
  "type": "object",
  "required": ["campaign_id", "name", "product_type", "status", "start_at", "end_at"],
  "properties": {
    "campaign_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "product_type": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["published", "draft", "expired"]
    },
    "start_at": {
      "type": "string",
      "format": "date-time"
    },
    "end_at": {
      "type": "string",
      "format": "date-time"
    },
    "landing_page_url": {
      "type": "string",
      "minLength": 1
    },
    "highlights": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
