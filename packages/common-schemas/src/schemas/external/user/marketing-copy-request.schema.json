{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/user/marketing-copy-request.schema.json",
  "title": "MarketingCopyRequest",
  "type": "object",
  "required": [
    "campaign_id",
    "topic",
    "audience",
    "tone",
    "keywords"
  ],
  "properties": {
    "campaign_id": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "audience": {
      "type": "string",
      "minLength": 1
    },
    "tone": {
      "type": "string",
      "enum": [
        "professional",
        "growth",
        "launch"
      ]
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
