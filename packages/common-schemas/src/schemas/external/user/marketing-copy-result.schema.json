{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/user/marketing-copy-result.schema.json",
  "title": "MarketingCopyResult",
  "type": "object",
  "required": [
    "copy_id",
    "campaign_id",
    "campaign_name",
    "topic",
    "audience",
    "tone",
    "headline",
    "summary",
    "body",
    "call_to_action",
    "keywords",
    "created_at"
  ],
  "properties": {
    "copy_id": {
      "type": "string",
      "minLength": 1
    },
    "campaign_id": {
      "type": "string",
      "minLength": 1
    },
    "campaign_name": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "audience": {
      "type": "string",
      "minLength": 1
    },
    "tone": {
      "type": "string",
      "enum": [
        "professional",
        "growth",
        "launch"
      ]
    },
    "headline": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "body": {
      "type": "string",
      "minLength": 1
    },
    "call_to_action": {
      "type": "string",
      "minLength": 1
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "landing_page_url": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
