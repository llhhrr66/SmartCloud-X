{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/user/poster-task-create-response-data.schema.json",
  "title": "PosterTaskCreateResponseData",
  "type": "object",
  "required": ["task_id", "status", "estimated_seconds"],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed"]
    },
    "estimated_seconds": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
