{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/user/poster-task.schema.json",
  "title": "PosterTask",
  "type": "object",
  "required": ["task_id", "status", "campaign_id", "theme", "size", "created_at"],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed"]
    },
    "campaign_id": {
      "type": "string",
      "minLength": 1
    },
    "campaign_name": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "string",
      "minLength": 1
    },
    "slogan": {
      "type": "string",
      "minLength": 1
    },
    "size": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "image_url": {
      "type": "string",
      "minLength": 1
    },
    "error_message": {
      "type": "string",
      "minLength": 1
    },
    "estimated_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
