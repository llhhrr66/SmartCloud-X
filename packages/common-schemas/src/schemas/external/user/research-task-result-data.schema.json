{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/user/research-task-result-data.schema.json",
  "title": "ResearchTaskResultData",
  "type": "object",
  "required": [
    "task_id",
    "status",
    "result_ready",
    "output_format"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed"]
    },
    "result_ready": {
      "type": "boolean"
    },
    "output_format": {
      "type": "string",
      "enum": ["markdown", "pdf"]
    },
    "summary": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "report_file_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "download_url": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "preview_text": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "generated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
