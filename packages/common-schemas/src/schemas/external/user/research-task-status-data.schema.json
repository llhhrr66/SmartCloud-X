{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/user/research-task-status-data.schema.json",
  "title": "ResearchTaskStatusData",
  "type": "object",
  "required": [
    "task_id",
    "status",
    "progress",
    "created_at",
    "result_ready"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed"]
    },
    "progress": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "started_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "finished_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "result_ready": {
      "type": "boolean"
    },
    "report_file_id": {
      "type": ["string", "null"],
      "minLength": 1
    }
  },
  "additionalProperties": false
}
