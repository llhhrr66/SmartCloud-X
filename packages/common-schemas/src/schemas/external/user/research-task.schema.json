{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/external/user/research-task.schema.json",
  "title": "ResearchTask",
  "type": "object",
  "required": ["task_id", "status", "topic", "scope", "depth", "output_format", "progress", "created_at"],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed"]
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "depth": {
      "type": "string",
      "enum": ["lite", "standard", "deep"]
    },
    "output_format": {
      "type": "string",
      "enum": ["markdown", "pdf"]
    },
    "progress": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "report_file_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "finished_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "error_message": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
