{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/health-status.schema.json",
  "title": "HealthStatus",
  "type": "object",
  "required": ["status", "service"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "degraded", "error"]
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["ok", "degraded", "error"]
      }
    }
  },
  "additionalProperties": false
}
