{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/agent-descriptor.schema.json",
  "title": "AgentDescriptor",
  "type": "object",
  "required": [
    "name",
    "domain"
  ],
  "properties": {
    "name": {
      "$ref": "./agent-name.schema.json"
    },
    "code": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "input_schema_version": {
      "type": "string",
      "minLength": 1
    },
    "output_schema_version": {
      "type": "string",
      "minLength": 1
    },
    "default_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supported_scenes": {
      "type": "array",
      "items": {
        "$ref": "./scene-name.schema.json"
      }
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fallback_agent": {
      "type": "string",
      "minLength": 1
    },
    "max_tool_calls": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}
