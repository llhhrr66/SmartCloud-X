{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/agent-execution-result.schema.json",
  "title": "AgentExecutionResult",
  "type": "object",
  "required": [
    "agent",
    "reasoning_summary"
  ],
  "properties": {
    "agent": {
      "$ref": "./agent-name.schema.json"
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "completed",
        "needs-human",
        "success",
        "handoff",
        "need_user_input",
        "failed"
      ]
    },
    "reasoning_summary": {
      "type": "string",
      "minLength": 1
    },
    "tool_calls": {
      "type": "array",
      "items": {
        "$ref": "./tool-invocation.schema.json"
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "final_answer": {
      "type": [
        "string",
        "null"
      ]
    },
    "handoff_received_from": {
      "oneOf": [
        {
          "$ref": "./agent-name.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "next_agent": {
      "oneOf": [
        {
          "$ref": "./agent-name.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "action_required": {
      "type": [
        "string",
        "null"
      ]
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "$ref": "./agent-execution-risk-flag.schema.json"
      }
    },
    "trace_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "handoff_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "handoff_payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
