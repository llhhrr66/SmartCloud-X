{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/agent-task.schema.json",
  "title": "AgentTask",
  "type": "object",
  "required": ["agent", "reason"],
  "properties": {
    "agent": {
      "$ref": "./agent-name.schema.json"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "requires_retrieval": {
      "type": "boolean"
    },
    "suggested_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "handoff_step_id": {
      "type": ["string", "null"]
    },
    "depends_on_tool_call_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "session_context_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "session_context_outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
