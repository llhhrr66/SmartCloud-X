{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/chat-message-record.schema.json",
  "title": "ChatMessageRecord",
  "type": "object",
  "required": [
    "message_id",
    "conversation_id",
    "role",
    "message_type",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "enum": [
        "user",
        "assistant",
        "system"
      ]
    },
    "message_type": {
      "type": "string",
      "enum": [
        "user_input",
        "assistant_response",
        "event"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "running",
        "completed",
        "handoff",
        "need_user_input",
        "failed",
        "cancelled"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "parent_message_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "agent_name": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "content": {
      "type": [
        "string",
        "null"
      ]
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tool_calls": {
      "type": "array",
      "items": {
        "$ref": "./tool-invocation.schema.json"
      }
    },
    "finish_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "trace": {
      "oneOf": [
        {
          "$ref": "../../trace-context.schema.json"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
