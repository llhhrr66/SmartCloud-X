{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/compensation-execution-record.schema.json",
  "title": "CompensationExecutionRecord",
  "type": "object",
  "required": [
    "step_id",
    "tool_name",
    "action_name",
    "status",
    "success",
    "message"
  ],
  "properties": {
    "step_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "action_name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "failed"
      ]
    },
    "success": {
      "type": "boolean"
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    },
    "provider": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "retryable": {
      "type": "boolean"
    },
    "latency_ms": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "error_detail": {
      "type": "object",
      "additionalProperties": true
    },
    "idempotency_key": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  },
  "additionalProperties": false
}
