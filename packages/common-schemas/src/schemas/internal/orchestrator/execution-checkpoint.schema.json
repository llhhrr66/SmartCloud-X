{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/execution-checkpoint.schema.json",
  "title": "ExecutionCheckpoint",
  "type": "object",
  "required": [
    "name",
    "description"
  ],
  "properties": {
    "name": {
      "description": "Checkpoint identifier. The current additive orchestrator baseline may emit names such as `review-answer` before optional `human-review` escalation.",
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "pending",
        "completed",
        "skipped",
        "failed"
      ]
    }
  },
  "additionalProperties": false
}
