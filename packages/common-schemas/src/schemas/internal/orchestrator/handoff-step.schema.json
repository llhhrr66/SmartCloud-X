{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/handoff-step.schema.json",
  "title": "HandoffStep",
  "type": "object",
  "required": ["step_id", "order", "agent", "objective"],
  "properties": {
    "step_id": {
      "type": "string",
      "minLength": 1
    },
    "order": {
      "type": "integer",
      "minimum": 0
    },
    "agent": {
      "$ref": "./agent-name.schema.json"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requires_retrieval": {
      "type": "boolean"
    },
    "tool_names": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "depends_on_tool_call_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "session_context_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "session_context_outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exit_criteria": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
