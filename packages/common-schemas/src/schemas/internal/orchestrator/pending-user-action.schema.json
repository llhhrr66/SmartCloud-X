{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/pending-user-action.schema.json",
  "title": "PendingUserAction",
  "type": "object",
  "required": [
    "tool_name",
    "tool_call_id",
    "action",
    "message"
  ],
  "properties": {
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "tool_call_id": {
      "type": "string",
      "minLength": 1
    },
    "agent": {
      "oneOf": [
        {
          "$ref": "./agent-name.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "clarify-tool-input",
        "collect-auth-context",
        "user-confirmation"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "missing_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_payload_hints": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_auth_context": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requires_account_context": {
      "type": "boolean"
    },
    "confirmation_required": {
      "type": "boolean"
    },
    "session_context_bindings": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "confirm_tool_names": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
