{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/response-review-issue.schema.json",
  "title": "ResponseReviewIssue",
  "type": "object",
  "required": [
    "code",
    "severity",
    "message"
  ],
  "properties": {
    "code": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "warning",
        "error"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
