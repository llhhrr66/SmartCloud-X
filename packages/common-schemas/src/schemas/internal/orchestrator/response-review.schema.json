{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/response-review.schema.json",
  "title": "ResponseReview",
  "type": "object",
  "required": [
    "status",
    "summary",
    "issues",
    "requires_escalation"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "approved",
        "warning",
        "blocked",
        "skipped"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "./response-review-issue.schema.json"
      }
    },
    "requires_escalation": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
