{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/session-cancel-response.schema.json",
  "title": "SessionCancelResponse",
  "type": "object",
  "required": [
    "conversation_id",
    "message_id",
    "status",
    "cancelled"
  ],
  "properties": {
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "cancelled"
      ]
    },
    "cancelled": {
      "const": true
    }
  },
  "additionalProperties": false
}
