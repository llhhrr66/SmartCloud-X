{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/session-list-response.schema.json",
  "title": "SessionListResponse",
  "type": "object",
  "required": [
    "items",
    "total",
    "page",
    "page_size"
  ],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "$ref": "./conversation-record.schema.json"
      }
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "page": {
      "type": "integer",
      "minimum": 1
    },
    "page_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    }
  },
  "additionalProperties": false
}
