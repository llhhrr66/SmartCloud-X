{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/stream-citation-entry.schema.json",
  "title": "OrchestratorStreamCitationEntry",
  "type": "object",
  "required": [
    "id",
    "title",
    "source_type"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "knowledge_base",
        "tool",
        "mixed"
      ]
    },
    "doc_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "chunk_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  },
  "additionalProperties": true
}
