{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/stream-retrieval-source.schema.json",
  "title": "OrchestratorStreamRetrievalSource",
  "type": "object",
  "required": [
    "sourceId",
    "sourceType",
    "title"
  ],
  "properties": {
    "sourceId": {
      "type": "string",
      "minLength": 1
    },
    "sourceType": {
      "type": "string",
      "enum": [
        "knowledge_base",
        "tool",
        "mixed"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "docId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "chunkId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "score": {
      "type": [
        "number",
        "null"
      ]
    },
    "uri": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "snippet": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "backendUsed": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "domain": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  },
  "additionalProperties": true
}
