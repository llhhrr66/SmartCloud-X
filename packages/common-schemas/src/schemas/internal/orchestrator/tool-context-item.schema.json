{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/tool-context-item.schema.json",
  "title": "ToolContextItem",
  "type": "object",
  "required": [
    "tool_name",
    "tool_call_id",
    "status"
  ],
  "properties": {
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "tool_call_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "provider": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    },
    "patch_keys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
