{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/tool-invocation.schema.json",
  "title": "ToolInvocation",
  "type": "object",
  "required": [
    "tool_name",
    "operation",
    "status"
  ],
  "properties": {
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "tool_call_id": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "auth_required": {
      "type": "boolean"
    },
    "success": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "retryable": {
      "type": "boolean"
    },
    "latency_ms": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "compensation": {
      "oneOf": [
        {
          "$ref": "../tool-hub/tool-compensation-action.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "provider": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "audit_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "error_detail": {
      "type": "object",
      "properties": {
        "missing_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "idempotency_key": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "session_context_patch": {
      "$ref": "../orchestrator/session-context.schema.json"
    },
    "user_action_hint": {
      "oneOf": [
        {
          "$ref": "../tool-hub/tool-user-action-hint.schema.json"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
