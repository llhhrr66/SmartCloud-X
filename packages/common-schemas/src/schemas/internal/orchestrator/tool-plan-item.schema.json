{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/orchestrator/tool-plan-item.schema.json",
  "title": "ToolPlanItem",
  "type": "object",
  "required": [
    "tool_name",
    "assigned_agent",
    "reason"
  ],
  "properties": {
    "tool_call_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "assigned_agent": {
      "$ref": "./agent-name.schema.json"
    },
    "operation": {
      "$ref": "../tool-hub/tool-operation.schema.json"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "required_payload_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_payload_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deferred_payload_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_payload_hints": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "depends_on_tool_call_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "session_context_input_keys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "session_context_output_keys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "readiness": {
      "type": "string",
      "enum": [
        "ready",
        "ready_after_dependencies",
        "needs_user_input"
      ]
    },
    "auth_required": {
      "type": "boolean"
    },
    "requires_account_context": {
      "type": "boolean"
    },
    "required_permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "high_risk": {
      "type": "boolean"
    },
    "tool_mode": {
      "$ref": "../tool-hub/tool-mode.schema.json"
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1
    },
    "idempotent": {
      "type": "boolean"
    },
    "cache_ttl_seconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    }
  },
  "additionalProperties": false
}
