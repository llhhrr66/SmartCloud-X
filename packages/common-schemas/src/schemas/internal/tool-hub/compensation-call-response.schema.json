{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/tool-hub/compensation-call-response.schema.json",
  "title": "CompensationCallResponse",
  "type": "object",
  "required": [
    "success",
    "code",
    "message",
    "compensation_id",
    "action_name",
    "latency_ms"
  ],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "code": {
      "type": "integer"
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    },
    "compensation_id": {
      "type": "string",
      "minLength": 1
    },
    "action_name": {
      "type": "string",
      "minLength": 1
    },
    "latency_ms": {
      "type": "integer",
      "minimum": 0
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "error": {
      "oneOf": [
        {
          "$ref": "./tool-call-error.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "idempotency_key": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "attempts": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}
