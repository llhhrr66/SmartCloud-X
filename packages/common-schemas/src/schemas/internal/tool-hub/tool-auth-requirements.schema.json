{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/tool-hub/tool-auth-requirements.schema.json",
  "title": "ToolAuthRequirements",
  "type": "object",
  "properties": {
    "require_user_id": {
      "type": "boolean"
    },
    "require_account_id": {
      "type": "boolean"
    },
    "allowed_roles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confirmation_required": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
