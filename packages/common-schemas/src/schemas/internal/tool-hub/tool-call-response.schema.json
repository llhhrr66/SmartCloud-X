{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/tool-hub/tool-call-response.schema.json",
  "title": "ToolCallResponse",
  "type": "object",
  "required": [
    "success",
    "code",
    "message",
    "tool_call_id",
    "latency_ms"
  ],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "code": {
      "type": "integer"
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "object",
      "additionalProperties": true
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    },
    "audit_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tool_call_id": {
      "type": "string",
      "minLength": 1
    },
    "latency_ms": {
      "type": "integer",
      "minimum": 0
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "error": {
      "oneOf": [
        {
          "$ref": "./tool-call-error.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "compensation": {
      "oneOf": [
        {
          "$ref": "./tool-compensation-action.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "idempotency_key": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "attempts": {
      "type": "integer",
      "minimum": 1
    },
    "session_context_patch": {
      "$ref": "../orchestrator/session-context.schema.json"
    },
    "user_action_hint": {
      "oneOf": [
        {
          "$ref": "./tool-user-action-hint.schema.json"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
