{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/tool-hub/tool-definition.schema.json",
  "title": "ToolDefinition",
  "type": "object",
  "required": [
    "name",
    "capability",
    "description"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "capability": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "$ref": "./tool-mode.schema.json"
    },
    "supported_operations": {
      "type": "array",
      "items": {
        "$ref": "./tool-operation.schema.json"
      }
    },
    "input_schema": {
      "type": "object",
      "additionalProperties": true
    },
    "input_schema_hint": {
      "type": "object",
      "additionalProperties": true
    },
    "input_field_hints": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "output_schema": {
      "type": "object",
      "additionalProperties": true
    },
    "output_schema_hint": {
      "type": "object",
      "additionalProperties": true
    },
    "session_context_bindings": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "session_context_output_keys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prerequisite_tool_names": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "operation_required_fields": {
      "type": "object",
      "properties": {
        "preview": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "execute": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "auth_requirements": {
      "$ref": "./tool-auth-requirements.schema.json"
    },
    "downstream_target": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1
    },
    "idempotent": {
      "type": "boolean"
    },
    "idempotency_window_seconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "high_risk": {
      "type": "boolean"
    },
    "cache_ttl_seconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    }
  },
  "additionalProperties": false
}
