{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/tool-hub/tool-invocation-request.schema.json",
  "title": "ToolInvocationRequest",
  "type": "object",
  "required": ["tool_name"],
  "properties": {
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "$ref": "./tool-operation.schema.json"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "context": {
      "$ref": "./tool-execution-context.schema.json"
    },
    "trace": {
      "oneOf": [
        {
          "$ref": "../../trace-context.schema.json"
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    }
  },
  "additionalProperties": false
}
