{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/internal/tool-hub/tool-user-action-hint.schema.json",
  "title": "ToolUserActionHint",
  "description": "Machine-readable continuation guidance surfaced by business-tools or tool-hub when a tool call needs payload clarification, auth context, or explicit confirmation. Auth-required hints may map missing auth context onto `/continue.user_profile_patch` fields through `user_profile_bindings`.",
  "type": "object",
  "required": [
    "action",
    "message"
  ],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "clarify-tool-input",
        "collect-auth-context",
        "user-confirmation"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "missing_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_payload_hints": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_auth_context": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requires_account_context": {
      "type": "boolean"
    },
    "confirmation_required": {
      "type": "boolean"
    },
    "session_context_bindings": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "user_profile_bindings": {
      "type": "object",
      "description": "Maps additive `/continue.user_profile_patch` fields onto the user/account/role/permission inputs that can satisfy the missing auth context.",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "confirm_tool_names": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "examples": [
    {
      "action": "collect-auth-context",
      "message": "billing.create_invoice 执行前需补充鉴权上下文。",
      "missing_auth_context": [
        "account_id",
        "permission:user:billing.read"
      ],
      "required_permissions": [
        "user:billing.read"
      ],
      "requires_account_context": true,
      "user_profile_bindings": {
        "account_id": [
          "account_id"
        ],
        "permissions": [
          "permissions"
        ]
      }
    }
  ],
  "additionalProperties": false
}
