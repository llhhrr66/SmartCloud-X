{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/pagination-meta.schema.json",
  "title": "PaginationMeta",
  "type": "object",
  "properties": {
    "page": {
      "type": "integer",
      "minimum": 1
    },
    "pageSize": {
      "type": "integer",
      "minimum": 1
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "nextCursor": {
      "type": "string",
      "minLength": 1
    },
    "hasMore": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
