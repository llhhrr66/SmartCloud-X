{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/runtime-readiness-status.schema.json",
  "title": "RuntimeReadinessStatus",
  "type": "object",
  "required": [
    "status",
    "service",
    "not_ready_components",
    "runtime"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "not_ready"
      ]
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "not_ready_components": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
