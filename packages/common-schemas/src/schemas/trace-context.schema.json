{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcloud-x.local/schemas/trace-context.schema.json",
  "title": "TraceContext",
  "description": "Shared correlation context for internal ApiEnvelope responses. Optional scope members may be omitted or explicit null when the current response has no conversation, user, tenant, caller-service, tool-call, idempotency, or operator-reason context.",
  "type": "object",
  "required": [
    "traceId"
  ],
  "properties": {
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "traceId": {
      "type": "string",
      "minLength": 1
    },
    "conversationId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "userId": {
      "type": [
        "string",
        "null"
      ]
    },
    "tenantId": {
      "type": [
        "string",
        "null"
      ]
    },
    "callerService": {
      "type": [
        "string",
        "null"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "toolCallId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "idempotencyKey": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "operatorReason": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 3,
      "maxLength": 500
    }
  },
  "examples": [
    {
      "requestId": "6e0e0c5b-af7f-4322-885b-45103788869f",
      "traceId": "6e0e0c5b-af7f-4322-885b-45103788869f",
      "conversationId": null,
      "tenantId": null,
      "callerService": null
    }
  ],
  "additionalProperties": false
}
