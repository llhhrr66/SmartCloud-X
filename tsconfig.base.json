{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@smartcloud-x/common": ["packages/common/src/index.ts"],
      "@smartcloud-x/common/*": ["packages/common/src/*"],
      "@smartcloud-x/common-schemas": ["packages/common-schemas/src/index.ts"],
      "@smartcloud-x/common-schemas/*": ["packages/common-schemas/src/*"],
      "@smartcloud-x/common-auth": ["packages/common-auth/src/index.ts"],
      "@smartcloud-x/common-auth/*": ["packages/common-auth/src/*"]
    }
  }
}
